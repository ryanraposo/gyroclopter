# Logs & Diagnostics
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================
# Runtime & Environment Files (Sensitive Data)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*

# ==========================================
# Testing & Coverage
# ==========================================
coverage/
.nyc_output/

# ==========================================
# Build Outputs & Bundles
# ==========================================
dist/
build/
out/
.next/
.nuxt/
.cache/
# Compiled standalone binaries (like pkg or Bun compile outputs)
*.exe
*.pkg
*.app

# Hermes configuration directory
.hermes

# ==========================================
# TypeScript & Cache
# ==========================================
*.tsbuildinfo
.eslintcache
.stylelintcache

# ==========================================
# OS Files (System Clutter)
# ==========================================
.DS_Store
Thumbs.db
.aider*

# ==========================================
