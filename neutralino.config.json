{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "com.gyroclopter.desktop",
  "version": "0.4.0",
  "defaultMode": "window",
  "defaultPort": 0,
  "url": "/",
  "documentRoot": "resources/",
  "enableServer": true,
  "enableNativeAPI": true,
  "nativeAllowList": [
    "app.*",
    "events.*",
    "filesystem.*",
    "os.*",
    "res.*",
    "tray.*",
    "window.*"
  ],
  "modes": {
    "window": {
      "title": "Gyroclopter",
      "width": 480,
      "height": 680,
      "minWidth": 380,
      "minHeight": 560,
      "icon": "desktop/icons/appIcon.png",
      "enableInspector": true,
      "exitProcessOnClose": false
    }
  },
  "cli": {
    "binaryName": "gyroclopter",
    "resourcesPath": "resources/",
    "extensionsPath": "/extensions/",
    "binaryVersion": "6.8.0",
    "targets": [
      "linux-x64",
      "win-x64",
      "macos-x64"
    ]
  }
}