{
  "name": "gyroclopter",
  "version": "0.4.0",
  "description": "Neutralinojs desktop app + headless server for wireless gyroscopic air mouse.",
  "author": {
    "name": "ryanraposo",
    "email": "raposo.ryan@gmail.com"
  },
  "homepage": "https://github.com/ryanraposo/gyroclopter#readme",
  "bugs": {
    "url": "https://github.com/ryanraposo/gyroclopter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanraposo/gyroclopter.git"
  },
  "license": "ISC",
  "type": "commonjs",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "test": "jest",
    "build:icons": "node scripts/build-icon.js",
    "build:server": "node scripts/build-binary.js",
    "build:desktop": "node scripts/build-desktop.js",
    "build:win-installer": "node scripts/build-installer-nsi.js",
    "build:linux": "node scripts/build-deb.js",
    "clean": "node -e \"const fs=require('fs');['dist','resources'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "dev": "node scripts/build-desktop.js --dev && npx neu run",
    "build": "npm run clean && npm run build:icons && npm run build:server && npm run build:desktop && npm run build:win-installer"
  },
  "devDependencies": {
    "@neutralinojs/neu": "^11.7.2",
    "@yao-pkg/pkg": "^6.20.0",
    "adm-zip": "^0.5.17",
    "jest": "^29.7.0",
    "pngjs": "^7.0.0"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0",
    "ws": "^8.21.0"
  }
}
