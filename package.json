{
  "name": "gyroclopter",
  "version": "0.5.0",
  "description": "Electron desktop app + headless server for wireless gyroscopic air mouse.",
  "author": {
    "name": "ryanraposo",
    "email": "raposo.ryan@gmail.com"
  },
  "homepage": "https://github.com/ryanraposo/gyroclopter#readme",
  "bugs": {
    "url": "https://github.com/ryanraposo/gyroclopter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanraposo/gyroclopter.git"
  },
  "license": "ISC",
  "type": "commonjs",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "build:icons": "node build-icon.js",
    "clean": "node -e \"const fs=require('fs');['dist','resources'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",

    "build": "npm run clean && npm run build:icons && electron-builder --win --linux",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",

    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "changelog:all": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "release": "npm run changelog && git add CHANGELOG.md"
  },
  "devDependencies": {
      "conventional-changelog-cli": "^4.1.0",
      "jest": "^29.7.0",
      "pngjs": "^7.0.0",
      "electron": "^30.5.1",
      "electron-builder": "^24.13.3"
    },
  "dependencies": {
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0",
    "ws": "^8.21.0"
  },
  "build": {
    "appId": "com.raposo.gyroclopter",
    "productName": "Gyroclopter",
    "files": [
      "app/**/*",
      "server.js",
      "client.html"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "publisherName": "Ryan Raposo",
      "signingHashAlgorithms": ["sha256"]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "linux": {
      "target": "deb",
      "icon": "build/icons",
      "category": "Utility",
      "maintainer": "Ryan Raposo <raposo.ryan@gmail.com>"
    }
  }
}