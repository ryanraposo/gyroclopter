{
  "name": "gyroclopter",
  "version": "0.5.0",
  "description": "Wireless gyroscopic air mouse.",
  "author": {
    "name": "ryanraposo",
    "email": "raposo.ryan@gmail.com"
  },
  "homepage": "https://github.com/ryanraposo/gyroclopter#readme",
  "bugs": {
    "url": "https://github.com/ryanraposo/gyroclopter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanraposo/gyroclopter.git"
  },
  "license": "ISC",
  "type": "commonjs",
  "main": "app/electron-main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "test:playwright": "npx playwright test",
    "build:icons": "node scripts/build-icon.js",
    "clean": "node -e \"const fs=require('fs');['dist','resources'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "build": "npm run clean && npm run build:icons && electron-builder --win --linux",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.6",
    "jest": "^29.7.0",
    "png-to-ico": "^3.0.1",
    "pngjs": "^7.0.0",
    "sharp": "^0.35.3"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/playwright/"
    ]
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0",
    "ws": "^8.21.0"
  },
  "build": {
    "appId": "com.raposo.gyroclopter",
    "productName": "Gyroclopter",
    "artifactName": "${name}-${version}.${ext}",
    "files": [
      "app/**/*",
      "server.js",
      "client.html"
    ],
    "extraResources": [],
    "directories": {
      "buildResources": "build"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "linux": {
      "target": "deb",
      "icon": "build/icons",
      "category": "Utility",
      "maintainer": "Ryan Raposo <raposo.ryan@gmail.com>",
      "executableArgs": [
        "--no-sandbox"
      ]
    }
  }
}
