{
  "name": "gyroclopter",
  "version": "0.2.0",
  "description": "CLI, QR, LAN-exposed gyroscopic remote pointer for Windows/iOS with SSL.",
  "author": {
    "name": "ryanraposo",
    "email": "raposo.ryan@gmail.com"
  },
  "homepage": "https://github.com/ryanraposo/gyroclopter#readme",
  "bugs": {
    "url": "https://github.com/ryanraposo/gyroclopter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanraposo/gyroclopter.git"
  },
  "license": "ISC",
  "type": "commonjs",
  "main": "server.js",
  "desktopName": "Gyroclopter",
  "scripts": {
    "start": "node server.js",
    "test": "jest",
    "icons:generate": "node scripts/generate-icons.js && node scripts/generate-ico.js",
    "prepack": "npm run icons:generate",
    "predist": "npm run icons:generate",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.ryanraposo.gyroclopter",
    "productName": "Gyroclopter",
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icons",
      "syncDesktopName": true,
      "synopsis": "Gyroscopic air mouse that turns your phone into a wireless remote pointer.",
      "description": "Gyroclopter turns a mobile phone into a wireless gyroscopic air mouse for a desktop computer. It runs a tiny HTTPS/WebSocket server on the desktop and serves a full-screen mobile web client.",
      "desktop": {
        "entry": {
          "Name": "Gyroclopter",
          "Comment": "Gyroscopic air mouse that turns your phone into a wireless remote pointer.",
          "Categories": "Utility;"
        }
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0",
    "ws": "^8.21.0"
  }
}
